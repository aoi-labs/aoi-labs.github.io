---
import Layout from '../layouts/Layout.astro';
import { Zap, Atom, Cpu, Bot, ArrowRight } from 'lucide-react';
---

<Layout title="AOI_LABS // AI & Robotics Developer">

	<section class="relative min-h-[90vh] flex items-center px-6 overflow-hidden border-b border-white/5">
		<div class="max-w-7xl mx-auto grid lg:grid-cols-12 gap-12 relative z-10">
			<div class="lg:col-span-7">
				<span class="font-headline text-primary tracking-[0.3em] text-[10px] uppercase mb-4 block">SYSTEM_STATE: OPERATIONAL</span>
				<h1 class="font-headline text-6xl md:text-8xl font-black leading-[0.85] uppercase mb-8">
					Bringing <span class="text-primary-container text-glow-primary">AI Companions</span> to Life.
				</h1>
				<p class="text-[#ababab] text-lg max-w-xl font-light mb-8">
					Engineering sentient architectures and robotic chassis that bridge the gap between silicon logic and biological warmth.
				</p>
				<div class="flex flex-wrap gap-4">
					 <a href="/projects" class="bg-primary-container text-black px-8 py-4 text-xs font-black uppercase tracking-widest shadow-[0_0_20px_rgba(228,247,0,0.3)] inline-block">
						Explore Projects
					</a>
					<a href="/about" class="border border-white/20 px-8 py-4 text-xs font-bold uppercase tracking-widest hover:bg-white/10 inline-block">
						View Dossier
					</a>
				</div>
			</div>
			<div class="lg:col-span-5 relative flex justify-center">
				<div class="absolute inset-0 bg-gradient-to-tr from-[#00eefc]/10 to-primary-container/20 blur-[100px] rounded-full"></div>
				<div class="relative z-10 w-full aspect-square border border-white/10 flex items-center justify-center bg-white/5 backdrop-blur-sm">
					<span class="text-[10px] uppercase tracking-widest opacity-30 italic">Target_Entity_Preview</span>
				</div>
			</div>
		</div>
	</section>

	<section id="vision" class="bg-white text-black py-32 px-6">
		<div class="max-w-7xl mx-auto grid lg:grid-cols-12 gap-16">
			<div class="lg:col-span-4 border-l-4 border-black pl-8">
				<h2 class="font-headline text-4xl font-bold leading-tight">Co-existence of Humans and AI Robots.</h2>
			</div>
			<div class="lg:col-span-8">
				<p class="text-2xl font-light leading-relaxed mb-8">
					My vision transcends mere automation. I believe in a future where robotics are not tools, but partners. By iteratively designing and building AI companion prototypes.

				</p>
				<div class="flex gap-16 pt-12 border-t border-black/10">
					<div>
						<span class="block text-5xl font-black">02+</span>
						<span class="text-[10px] uppercase tracking-widest opacity-60">Core Projects</span>
					</div>
					<div>
						<span class="block text-5xl font-black">01+</span>
						<span class="text-[10px] uppercase tracking-widest opacity-60">Expermental Projects</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-[#0e0e0e] py-32 px-6">
		<div class="max-w-7xl mx-auto">
			<div class="mb-20">
				<span class="font-headline text-secondary tracking-[0.2em] text-[10px] uppercase mb-2 block">TECHNICAL_MANIFEST</span>
				<h2 class="font-headline text-5xl md:text-7xl font-black uppercase leading-none">
					Projects & <br/><span class="text-primary-container text-glow-primary">Technical Synthesis</span>
				</h2>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
				<div class="md:col-span-2 lg:row-span-2 glass-card p-10 flex flex-col justify-between group border-l-4 border-primary-container">
					<div>
						<div class="text-primary-container mb-8 text-glow-primary">
							<Zap size={32} strokeWidth={2.5} client:load />
						</div>
						<h3 class="font-headline text-3xl font-bold mb-4 uppercase">Project_Aura: AI Companion Robot</h3>
						<p class="text-[#ababab] font-light leading-relaxed mb-8">
							An interactive companion robot powered by Raspberry Pi and Arduino. Featuring real-time voice recognition and emotive physical responses, with a custom chassis designed in Autodesk Fusion.
						</p>
					</div>
					<div class="flex justify-between items-end">
						<div class="flex gap-2">
							<span class="bg-white/5 px-3 py-1 text-[10px] font-bold uppercase tracking-wider border border-white/10">Raspberry Pi</span>
							<span class="bg-white/5 px-3 py-1 text-[10px] font-bold uppercase tracking-wider border border-white/10">Arduino</span>
							<span class="bg-white/5 px-3 py-1 text-[10px] font-bold uppercase tracking-wider border border-white/10">CAD/CAM</span>
						</div>
						<a href="/projects" class="group/btn flex items-center gap-2 text-primary-container text-[10px] font-black uppercase tracking-[0.2em] hover:brightness-125 transition-all">
							Explore All Projects
							<ArrowRight size={14} className="group-hover/btn:translate-x-1 transition-transform" />
						</a>
					</div>
				</div>

<div class="glass-card border-l border-secondary/50 p-8 flex flex-col items-center justify-start text-center gap-4 hover:border-l-[#e4f700] transition-colors group h-full">    <div class="text-secondary group-hover:scale-110 transition-transform h-12 flex items-center">
        <Atom size={32} strokeWidth={1.5} client:load />
    </div>
    <div>
        <h4 class="font-headline text-lg font-bold uppercase">Python 3.x</h4>
        <p class="text-[10px] text-[#ababab] uppercase tracking-widest mt-1 min-h-[30px] flex items-center justify-center">Deep Learning / Scripting</p>
    </div>
</div>

<div class="glass-card border-l border-secondary/50 p-8 flex flex-col items-center justify-start text-center gap-4 hover:border-l-[#e4f700] transition-colors group h-full">    <div class="text-secondary group-hover:scale-110 transition-transform h-12 flex items-center">
        <Cpu size={32} strokeWidth={1.5} client:load />
    </div>
    <div>
        <h4 class="font-headline text-lg font-bold uppercase">C++ Core</h4>
        <p class="text-[10px] text-[#ababab] uppercase tracking-widest mt-1 min-h-[30px] flex items-center justify-center">Arduino & Embedded Systems Control</p>
    </div>
</div>

<div class="lg:col-span-2 glass-card border-l border-secondary/50 p-8 flex justify-between items-center group hover:border-l-[#e4f700] transition-colors">    <div class="flex items-center gap-6">
        <div class="text-secondary group-hover:scale-110 transition-transform">
            <Bot size={36} strokeWidth={1.5} client:load />
        </div>
        <div>
            <span class="text-[10px] text-secondary mb-1 block tracking-widest uppercase opacity-70 font-bold">Hardware Design</span>
            <h3 class="font-headline text-2xl font-bold uppercase">Autodesk Fusion</h3>
        </div>
    </div>
    <div class="text-[10px] text-[#ababab] text-right font-light leading-tight uppercase tracking-tighter">
        CAD/CAM<br/>Robot Chassis & Mechanical Design
    </div>
</div>
			</div>
		</div>
	</section>

</Layout>