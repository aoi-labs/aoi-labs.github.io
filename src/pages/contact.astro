---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CONTACT // AOI_LABS">
  <style is:inline>
    .status-pulse {
        box-shadow: 0 0 0 0 rgba(228, 247, 0, 0.7);
        animation: pulse-ring 2s infinite;
    }
    @keyframes pulse-ring {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(228, 247, 0, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(228, 247, 0, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(228, 247, 0, 0); }
    }
    .glass-panel {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    @import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap');

    /* ボタンが他の要素の下に隠れないように強制する設定 */
    .force-clickable {
        position: relative !important;
        z-index: 999 !important;
        cursor: pointer !important;
        pointer-events: auto !important;
    }
  </style>

  <main class="relative z-10 min-h-[calc(100vh-80px)] flex items-center justify-center p-6">
   
    <div class="glass-panel w-full max-w-2xl p-8 md:p-12 relative overflow-hidden flex flex-col items-start gap-8 shadow-[0_0_50px_rgba(228,247,0,0.05)]">
     
      <div class="w-full flex justify-between items-center border-b border-white/10 pb-6">
        <div class="flex items-center gap-3">
          <div class="status-pulse w-2 h-2 rounded-full bg-[#e4f700]"></div>
          <span class="font-headline text-[10px] tracking-[0.3em] text-[#e4f700] uppercase">System: Operational</span>
        </div>
        <div class="font-headline text-[9px] tracking-[0.3em] text-white/30 uppercase">UPLINK_01</div>
      </div>

      <div class="space-y-4">
        <h1 class="font-headline text-5xl md:text-6xl font-bold tracking-tighter leading-none text-white uppercase">
          INITIATE <br/> <span class="text-[#e4f700]">COMMUNICATION</span>
        </h1>
        <p class="font-body text-[#adaaaa] text-base leading-relaxed max-w-md">
          Open to learning opportunities, collaboration, and technical projects. Feel free to reach out.
        </p>
      </div>

      <div class="w-full pt-4">
        <a
          href="mailto:aoi.sasakura@gmail.com"
          class="force-clickable flex items-center justify-center gap-3 bg-[#e4f700] hover:bg-[#d9eb00] text-black px-10 py-5 font-headline font-bold uppercase tracking-tighter transition-all"
        >
          <span class="material-symbols-outlined">mail</span>
          Establish Direct Link
        </a>
      </div>

      <div class="w-full flex justify-between items-center text-[9px] text-white/20 tracking-[0.2em] uppercase">
        <span>Response: &lt; 12ms</span>
        <span>Enc: AES-256</span>
      </div>

    </div>
  </main>
</Layout>
