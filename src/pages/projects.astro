          <span class="text-[10px] uppercase tracking-[0.3em] font-headline">Next_Experiment_Loading...</span>
        </div>

        <div class="border border-dashed border-white/10 rounded-sm flex flex-col items-center justify-center min-h-[300px] opacity-20 p-8 text-center gap-4">
           <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="M12 3v18"/><path d="M3 12h18"/></svg>
          <span class="text-[10px] uppercase tracking-[0.3em] font-headline">Next_Experiment_Loading...</span>
        </div>
      </div>
