          <div class="aspect-[16/10] bg-white/5 border-b border-white/10 relative overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1580894908321-96bc4ca91392?auto=format&fit=crop&q=80&w=600"
              alt="Game Narrative Screenshot"
              class="w-full h-full object-cover opacity-40 group-hover:opacity-70 group-hover:scale-105 transition-all duration-500"
            />
             <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <span class="text-[9px] uppercase tracking-[0.3em] text-white/20 font-headline italic">Game_Engine_Preview</span>
