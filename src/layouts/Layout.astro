---
interface Props {
  title: string;
}
const { title } = Astro.props;
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="ja" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;700;900&family=Inter:wght@300;400;700&display=swap" rel="stylesheet"/>
</head>
<body class="bg-[#0e0e0e] text-white font-body selection:bg-[#e4f700] selection:text-black min-h-screen flex flex-col">

  <nav class="fixed top-0 left-0 w-full z-50 bg-[#0e0e0e]/80 backdrop-blur-xl border-b border-[#f9ffb5]/10 px-4 md:px-6 py-4">
    <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-[200px_1fr_200px] items-center">
     
      <div class="flex justify-start">
        <a href="/" class="text-xl md:text-2xl font-black font-headline text-primary-container text-glow-primary hover:opacity-80 transition-opacity whitespace-nowrap">
          AOI_LABS
        </a>
      </div>

      <div class="flex justify-center">
        <div class="flex gap-x-4 md:gap-8 font-headline text-[9px] md:text-[10px] uppercase tracking-widest text-[#f9ffb5]/60">
          <a href="/projects" class="hover:text-[#00eefc] transition-colors whitespace-nowrap">Projects</a>
          <a href="/#vision" class="hover:text-[#00eefc] transition-colors whitespace-nowrap">Vision</a>
          <a href="/log" class="hover:text-[#00eefc] transition-colors whitespace-nowrap">Log</a>
          <a href="/about" class="hover:text-[#00eefc] transition-colors whitespace-nowrap">About</a>
          <a href="https://github.com/aoi-labs" target="_blank" class="hidden sm:block hover:text-[#00eefc] transition-colors whitespace-nowrap">GitHub</a>
        </div>
      </div>

      <div class="hidden md:flex justify-end">
        <a href="/contact" class="bg-primary-container text-black px-6 py-2 font-headline text-[10px] font-black uppercase tracking-[0.2em] hover:brightness-110 transition-all whitespace-nowrap">
          CONTACT
        </a>
      </div>

    </div>
  </nav>

  <div class="pt-20 md:pt-24 flex-grow">
    <slot />
  </div>

  <footer class="py-12 px-6 md:px-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8 mt-20">
    <a href="/" class="font-bold text-primary-container hover:opacity-80 transition-opacity">AOI_LABS</a>
   
    <div class="text-[9px] md:text-[10px] tracking-[0.2em] uppercase text-secondary text-glow-secondary text-center md:text-left">
      © 2026 AOI_SASAKURA // ALL_RIGHTS_RESERVED
    </div>

    <div class="flex gap-6 md:gap-8 text-[10px] tracking-widest opacity-60 uppercase">
      <a href="/log" class="hover:text-primary-container transition-colors">Log</a>
      <a href="/contact" class="hover:text-primary-container transition-colors">Contact</a>
    </div>
  </footer>

  <style is:global>
    :root {
      --primary-container: #e4f700;
      --secondary: #00eefc;
    }
    .font-headline { font-family: 'Space Grotesk', sans-serif; }
    .text-primary-container { color: var(--primary-container); }
    .bg-primary-container { background-color: var(--primary-container); }
    .text-glow-primary {
      text-shadow: 0 0 15px rgba(228, 247, 0, 0.6);
    }
    .text-glow-secondary {
      text-shadow: 0 0 10px rgba(0, 238, 252, 0.4);
    }
    .text-secondary { color: var(--secondary); }
    .glass-card {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
  </style>
</body>
</html>
